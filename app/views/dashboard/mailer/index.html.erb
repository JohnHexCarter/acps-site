<h1>Mailer Manager</h1>
<hr>
<ul class='nav nav-tabs' id='mailerTab' role='tablist'>
  <li class='nav-item' role='presentation'>
    <button class='nav-link active' id='drafts-tab' data-bs-toggle='tab' data-bs-target='#drafts' role='tab' aria-controls='drafts' aria-selected='true'>
      Drafted Mailers
    </button>
  </li>
  <li class='nav-item' role='presentation'>
    <button class='nav-link' id='published-tab' data-bs-toggle='tab' data-bs-target='#published' role='tab' aria-controls='published' aria-selected='false'>
      Published Mailers
    </button>
  </li>
  <li>
    <button class='nav-link' id='mle-tab' data-bs-toggle='tab' data-bs-target='#mle' role='tab' aria-controls='mle' aria-selected='false'>
      Confirmed Mailing List Entities
    </button>
  </li>
</ul>
<div class='tab-content' id='mailerContent'>
  <div class='tab-pane fade show active' id='drafts' role='tabpanel' aria-labelledby='drafts-tab'>
    <% if @mailer_drafts.count.zero? %>
      <div style='padding: 20px'>
        <h3>There are no draft Mailers at this time.</h3>
      </div>
    <% else %>
      <table class='table'>
        <thead>
          <tr>
            <th scope='col'>Subject</th>
            <th scope='col'>Last Edited</th>
            <th scope='col'>Edit</th>
          </tr>
        </thead>
        <tbody>
          <% @mailer_drafts.each do |draft| %>
            <tr>
              <td><%= link_to draft.subject, '#' %></td>
              <td><%= draft.updated_at.strftime('%F') %></td>
              <td><%= link_to 'Edit', '#' %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
  <div class='tab-pane fade' id='published' role='tabpanel' aria-labelledby='published-tab'>
    <% if @mailer_published.count.zero? %>
      <div style='padding: 20px'>
        <h3>There are no published Mailers at this time.</h3>
      </div>
    <% else %>
      <table class='table'>
        <thead>
          <tr>
            <th scope='col'>Subject</th>
            <th scope='col'>Published</th>
            <th scope='col'>Recipient List</th>
          </tr>
        </thead>
        <tbody>
          <% @mailer_published.each do |pub| %>
            <tr>
              <td><%= link_to pub.subject, '#' %></td>
              <td><%= pub.published_at.strftime('%F') %></td>
              <td><%= link_to 'Recipients', '#' %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
  <div class='tab-pane fade' id='mle' role='tabpanel' aria-labelledby='mle-tab'>
    <% if @confirmed_mle.count.zero? %>
      <div style='padding: 20px'>
        <h3>There are no confirmed Mailing List Entities at this time.</h3>
      </div>
    <% else %>
      <table class='table'>
        <thead>
          <tr>
            <th scope='col'>Email</th>
            <th scope='col'>Joined</th>
            <th scope='col'>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @confirmed_mle.each do |mle| %>
            <tr>
              <td><%= mle.email %></td>
              <td><%= mle.created_at.strftime('%F') %></td>
              <td><%= mle.aasm_state %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
