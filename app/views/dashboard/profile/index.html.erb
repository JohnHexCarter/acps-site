<h1>User Profile</h1>
<hr>
<div class='row'>
  <div class='mb-3'>
    <strong>Email:</strong> <%= current_user.email_address %>
    <% if @unverified %>
      <span style='color: red'>
        <%= bootstrap_icon 'x-octagon-fill', widht: 20, height: 20 %>
        Email is unverified.
      </span>
    <% else %>
      <span style='color: green'>
        <%= bootstrap_icon 'check-circle-fill', width: 20, height: 20 %>
      </span>
    <% end %>
  </div>
</div>
<hr>
<% if @unverified %>
  <div class='row'>
    <div class='mol-md'>
      <p>
        Email and Password cannot be changed until email is verified. Some site features will remain unavailable until your email is verified.
      </p>
      <p>
        <%= link_to send_verification_path do %>
          Please click here to send a verification email.
        <% end %>
      </p>
    </div>
  </div>
  <hr>
<% end %>
<div class='row'>
  <div class='col-md'>
    <h2>Change Email</h2>
    <%= form_with url: :update_email, method: :put do |form| %>
      <div class='mb-3'>
        <%= form.label :email_address, 'Email Address', class: 'form-label' %>
        <%= form.email_field :email_address, class: 'form-control', disabled: @unverified %>
      </div>
      <div class='text-end'>
        <%= form.submit 'Set New Email', class: 'btn btn-primary', disabled: @unverified %>
      </div>
    <% end %>
  </div>
  <div class='col-md'>
    <h2>Change Password</h2>
    <%= form_with url: :update_password, method: :put do |form| %>
      <div class='mb-3'>
        <%= form.label :current_password, 'Current Password', class: 'form-label' %>
        <%= form.password_field :current_password, class: 'form-control', disabled: @unverified %>
      </div>
      <div class='mb-3'>
        <%= form.label :new_password, 'New Password', class: 'form-label' %>
        <%= form.password_field :new_password, class: 'form-control', disabled: @unverified %>
      </div>
      <div class='mb-3'>
        <%= form.label :confirm_password, 'Confirm New Password', class: 'form-label' %>
        <%= form.password_field :confirm_password, class: 'form-control', disabled: @unverified %>
      </div>
      <div class='text-end'>
        <%= form.submit 'Set New Password', class: 'btn btn-primary', disabled: @unverified %>
      </div>
    <% end %>
  </div>
</div>
<hr>
<h2>Danger Territory</h2>
<div>
  <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#destroyModal">
    Delete Account
  </button>
</div>

<!-- Modal -->
<div class="modal fade" id="destroyModal" tabindex="-1" aria-labelledby="destroyModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="destroyModalLabel">Account Deletion</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete your account? This cannot be undone.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
        <%= button_to "Yes", dashboard_profile_path, method: :delete, data: { turbo_method: :delete }, class: "btn btn-danger" %>
      </div>
    </div>
  </div>
</div>
