<div class='col-auto col-md-3 col-xl-2 px-sm-2 px-0 bg-dark'>
  <div class='d-flex flex-column align-items-center align-items-sm-smart px-3 pt-2 text-white min-vh-100'>
    <%= link_to root_path, class: 'd-flex align-item-center pb-3 mb-md-0 me-md-auto text-white text-decoration-none' do %>
      <span class='fs-5 d-none d-sm-inline'>ACPS</span>
    <% end %>
    <ul class='nav nav-pills flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start' id='menu'>
      <li class='nav-item'>
        <%= link_to '/dashboard', class: 'nav-link align-middle px-0' do %>
          <%= bootstrap_icon 'house-fill', width: 20, height: 20 %>
          <span class='ms-1 d-none d-sm-inline'>
            Dashboard Home
          </span>
        <% end %>
      </li>
      <% @dash_objects.each do |dash_obj| %>
        <li class='nav-item'>
          <%= link_to "/dashboard/#{dash_obj.namespace}", class: 'nav-link align-middle px-0' do %>
            <%= bootstrap_icon dash_obj.icon_str, width: 20, height: 20 %>
            <span class='ms-1 d-none d-sm-inline'>
              <%= dash_obj.name %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
